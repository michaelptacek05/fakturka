generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VatPayerStatus {
  NON_PAYER
  PAYER
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
  OVERDUE
}

enum InvoiceAssetType {
  LOGO
  SIGNATURE
  STAMP
}

model UserProfile {
  id             String           @id @default(cuid())
  displayName    String
  companyName    String?
  street         String
  city           String
  postalCode     String
  country        String           @default("Česká republika")
  ico            String           @db.VarChar(16)
  dic            String?          @db.VarChar(20)
  registryText   String?
  vatPayerStatus VatPayerStatus   @default(NON_PAYER)
  accountNumber  String
  bankCode       String           @db.VarChar(10)
  iban           String?
  swift          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  assets         InvoiceAsset[]
  clients        Client[]
  invoices       Invoice[]
  sequences      InvoiceSequence[]
}

model Client {
  id            String        @id @default(cuid())
  profileId     String
  companyName   String?
  fullName      String?
  street        String
  city          String
  postalCode    String
  country       String        @default("Česká republika")
  ico           String?       @db.VarChar(16)
  dic           String?       @db.VarChar(20)
  email         String?
  phone         String?
  aresSyncedAt  DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  invoices      Invoice[]
  profile       UserProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([ico])
}

model InvoiceSequence {
  id          String       @id @default(cuid())
  profileId   String
  name        String       @default("Výchozí")
  format      String       @default("YYYYMM###")
  nextNumber  Int          @default(1)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  invoices    Invoice[]
  profile     UserProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Invoice {
  id                String           @id @default(cuid())
  profileId         String
  clientId          String
  sequenceId        String?
  number            String
  variableSymbol    String
  constantSymbol    String?
  specificSymbol    String?
  status            InvoiceStatus    @default(DRAFT)
  issueDate         DateTime
  taxableSupplyDate DateTime?
  dueDate           DateTime
  paidAt            DateTime?
  currency          String           @default("CZK") @db.VarChar(3)
  subtotal          Decimal          @default(0) @db.Decimal(12, 2)
  vatTotal          Decimal          @default(0) @db.Decimal(12, 2)
  total             Decimal          @default(0) @db.Decimal(12, 2)
  notes             String?
  qrPaymentPayload  String?
  pdfPath           String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  client            Client           @relation(fields: [clientId], references: [id], onDelete: Restrict)
  items             InvoiceItem[]
  profile           UserProfile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  sequence          InvoiceSequence? @relation(fields: [sequenceId], references: [id], onDelete: SetNull)

  @@unique([profileId, number])
  @@index([clientId])
  @@index([profileId, status])
  @@index([dueDate])
}

model InvoiceItem {
  id           String   @id @default(cuid())
  invoiceId    String
  position     Int
  name         String
  quantity     Decimal  @db.Decimal(12, 3)
  unit         String   @default("ks")
  unitPrice    Decimal  @db.Decimal(12, 2)
  vatRate      Decimal  @default(0) @db.Decimal(5, 2)
  lineSubtotal Decimal  @db.Decimal(12, 2)
  lineVat      Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceAsset {
  id          String           @id @default(cuid())
  profileId   String
  type        InvoiceAssetType
  fileName    String
  mimeType    String
  storagePath String
  createdAt   DateTime         @default(now())
  profile     UserProfile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, type])
}
